{
  "name": "@localhostlabs/qvac-bench",
  "version": "0.1.0-alpha.0",
  "description": "QVAC developer tooling package: qvac-bench",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qvac-bench": "dist/cli.js"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "verify:package": "pnpm lint && pnpm test && pnpm build && node scripts/verify-package.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
